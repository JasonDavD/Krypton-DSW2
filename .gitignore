# ===== Backend: Java / Maven =====
backend/target/
eureka-server/target/
catalogo-service/target/
pedidos-service/target/
api-gateway/target/
categorias-soap-service/target/
**/*.class

# Imágenes subidas en runtime (galería de productos): no versionar el contenido,
# pero mantener el directorio para que la app encuentre ./uploads en un clone fresco.
backend/uploads/*
!backend/uploads/.gitkeep

# ===== Frontend: Node (a futuro) =====
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.*

# ===== IDE / Editores =====
.idea/
*.iml
.vscode/
*.swp
*.swo

# ===== Sistema operativo =====
.DS_Store
Thumbs.db

# ===== Claude Code / tooling (config local, no versionar) =====
.claude/settings.local.json
.claude/skills/
.atl/

# ===== Logs =====
*.log

# Backups temporales del informe (no versionar)
*_backup.docx
